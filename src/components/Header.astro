---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
import { CATEGORY_LABELS, type BlogCategory } from "../utils/blog";

const categories = Object.keys(CATEGORY_LABELS) as BlogCategory[];
const q = Astro.url.searchParams.get("q") ?? "";
---

<header class="site-header">
	<a class="skip-link" href="#main">Bỏ qua menu, chuyển tới nội dung chính</a>

	<div class="header-top">
		<div class="header-top-inner">
			<p class="tagline">Cổng thông tin chính sách mặt hàng và thủ tục xuất nhập khẩu</p>
			<div class="header-top-links">
				<a href="/rss.xml">Tin RSS</a>
				<a href="https://customs.gov.vn/" target="_blank" rel="noopener noreferrer">Tổng cục Hải quan</a>
				<a href="https://vntr.moit.gov.vn/vi" target="_blank" rel="noopener noreferrer">CSDL thương mại (VNTR)</a>
			</div>
		</div>
	</div>

	<div class="header-main">
		<a class="brand" href="/" aria-label="Về trang chủ cổng thông tin">
			<span class="brand-mark" aria-hidden="true"></span>
			<span class="brand-text">
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-sub">Tổng hợp tin bài — kèm tham chiếu văn bản pháp quy</span>
			</span>
		</a>

		<form class="header-search" action="/tim-kiem/" method="get" role="search">
			<label class="sr-only" for="nav-search-q">Tìm kiếm toàn văn trong cổng</label>
			<input
				id="nav-search-q"
				type="search"
				name="q"
				placeholder="Từ khóa, số HS, tên chuyên mục…"
				value={q}
				autocomplete="off"
			/>
			<button type="submit" class="btn-search" aria-label="Tìm kiếm">Tìm</button>
		</form>
	</div>

	<nav class="nav-bar" aria-label="Điều hướng chính">
		<ul class="nav-list">
			<li>
				<HeaderLink href="/">Trang chủ</HeaderLink>
			</li>
			<li class="has-dropdown">
				<details class="nav-details">
					<summary>Tin bài &amp; hướng dẫn</summary>
					<div class="dropdown-panel">
						<HeaderLink href="/blog/" matchPrefix="/blog" prefixExclude="chu-de"
							>Toàn bộ tin bài</HeaderLink
						>
						<HeaderLink href="/blog/chu-de/" matchPrefix="/blog/chu-de"
							>Phân loại theo chuyên mục</HeaderLink
						>
						<hr class="dropdown-hr" />
						<p class="dropdown-label">Chuyên mục</p>
						{
							categories.map((key) => (
								<HeaderLink href={`/blog/chu-de/${key}/`} matchPrefix={`/blog/chu-de/${key}`}>
									{CATEGORY_LABELS[key]}
								</HeaderLink>
							))
						}
					</div>
				</details>
			</li>
			<li class="has-dropdown">
				<details class="nav-details">
					<summary>Hỗ trợ tra cứu</summary>
					<div class="dropdown-panel">
						<HeaderLink href="/tim-kiem/" matchPrefix="/tim-kiem">Tìm trong toàn cổng</HeaderLink>
						<HeaderLink href="/tra-cuu/" matchPrefix="/tra-cuu">Chỉ mục mã HS và nhãn</HeaderLink>
						<hr class="dropdown-hr" />
						<p class="dropdown-label">Truy cập trực tiếp</p>
						<a class="dropdown-link" href="/tra-cuu/#ma-hs">Danh mục mã HS</a>
						<a class="dropdown-link" href="/tra-cuu/#nhan">Danh mục nhãn nội dung</a>
					</div>
				</details>
			</li>
			<li>
				<HeaderLink href="/about">Giới thiệu cổng</HeaderLink>
			</li>
		</ul>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--header-bg);
		border-bottom: 1px solid var(--border-strong);
		box-shadow: var(--shadow-sm);
	}

	.skip-link {
		position: absolute;
		left: 0.5rem;
		top: 0.35rem;
		padding: 0.4rem 0.75rem;
		background: var(--brand-ink);
		color: #fff;
		font-size: 0.8125rem;
		font-weight: 600;
		border-radius: var(--radius-sm);
		transform: translateY(-130%);
		transition: transform 0.15s ease;
		z-index: 100;
		text-decoration: none;
	}
	.skip-link:focus {
		transform: translateY(0);
		outline: none;
	}

	.header-top {
		background: linear-gradient(90deg, var(--brand-ink) 0%, var(--brand-deep) 55%, #1d4ed8 100%);
		color: #dbeafe;
		font-size: 0.8125rem;
		font-weight: 500;
		letter-spacing: 0.01em;
	}
	.header-top-inner {
		width: min(var(--layout-max), calc(100% - 1.5rem));
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 1.25rem;
		padding: 0.4rem 0.75rem;
	}
	.tagline {
		margin: 0;
		line-height: 1.4;
	}
	.header-top-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 1.1rem;
	}
	.header-top-links a {
		color: #bfdbfe;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.8125rem;
	}
	.header-top-links a:hover {
		color: #fff;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.header-main {
		width: min(var(--layout-max), calc(100% - 1.5rem));
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem 1.5rem;
		padding: 0.9rem 0.75rem 0.75rem;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		color: inherit;
		max-width: min(100%, 28rem);
	}
	.brand:hover .brand-title {
		color: var(--accent);
	}
	.brand-mark {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--radius-sm);
		background: linear-gradient(145deg, #1e40af 0%, #3b82f6 100%);
		flex-shrink: 0;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
	}
	.brand-text {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		line-height: 1.28;
	}
	.brand-title {
		font-size: 0.9375rem;
		font-weight: 700;
		color: var(--brand-ink);
		letter-spacing: -0.01em;
	}
	.brand-sub {
		font-size: 0.75rem;
		color: rgb(var(--gray));
		font-weight: 500;
		line-height: 1.35;
	}

	.header-search {
		display: flex;
		flex-wrap: nowrap;
		align-items: stretch;
		gap: 0.5rem;
		flex: 1;
		min-width: min(100%, 17rem);
		max-width: 28rem;
	}
	.header-search input {
		flex: 1;
		min-width: 0;
	}
	.btn-search {
		padding: 0 1rem;
		font-weight: 700;
		font-size: 0.875rem;
		color: #fff;
		background: var(--brand);
		border: none;
		border-radius: var(--radius-sm);
		cursor: pointer;
		white-space: nowrap;
		transition: background 0.15s;
	}
	.btn-search:hover {
		background: var(--brand-deep);
	}

	.nav-bar {
		width: min(var(--layout-max), calc(100% - 1.5rem));
		margin: 0 auto;
		padding: 0 0.5rem 0;
		border-top: 1px solid var(--border);
		background: #f8fafc;
	}
	.nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: stretch;
		gap: 0;
	}
	.nav-list > li > :global(a) {
		display: inline-flex;
		align-items: center;
		padding: 0.65rem 0.9rem;
		color: var(--brand-ink);
		font-weight: 600;
		font-size: 0.875rem;
		letter-spacing: 0.02em;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
	}
	.nav-list > li > :global(a:hover) {
		background: rgba(255, 255, 255, 0.7);
		color: var(--accent);
	}
	.nav-list > li > :global(a.active) {
		color: var(--brand);
		border-bottom-color: var(--accent);
		background: #fff;
	}

	.has-dropdown {
		position: relative;
	}
	.nav-details {
		position: relative;
		height: 100%;
	}
	.nav-details > summary {
		list-style: none;
		cursor: pointer;
		padding: 0.65rem 1.6rem 0.65rem 0.9rem;
		font-weight: 600;
		font-size: 0.875rem;
		letter-spacing: 0.02em;
		color: var(--brand-ink);
		user-select: none;
		position: relative;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
	}
	.nav-details > summary::-webkit-details-marker {
		display: none;
	}
	.nav-details > summary::after {
		content: "";
		position: absolute;
		right: 0.65rem;
		top: 50%;
		width: 0.35rem;
		height: 0.35rem;
		border-right: 2px solid rgb(var(--gray));
		border-bottom: 2px solid rgb(var(--gray));
		transform: translateY(-65%) rotate(45deg);
		opacity: 0.85;
	}
	.nav-details[open] > summary {
		background: #fff;
		color: var(--brand);
		border-bottom-color: var(--accent);
	}
	.nav-details[open] > summary::after {
		border-color: var(--accent);
		transform: translateY(-35%) rotate(225deg);
	}
	.nav-details > summary:hover {
		background: rgba(255, 255, 255, 0.7);
		color: var(--accent);
	}

	.dropdown-panel {
		position: absolute;
		left: 0;
		top: calc(100% + 0);
		min-width: min(20rem, calc(100vw - 2rem));
		max-width: min(26rem, calc(100vw - 1rem));
		padding: 0.6rem 0.5rem;
		background: var(--surface);
		border: 1px solid var(--border-strong);
		border-radius: 0 0 var(--radius) var(--radius);
		box-shadow: var(--shadow-md);
		display: flex;
		flex-direction: column;
		gap: 0.05rem;
		z-index: 60;
	}
	.dropdown-panel :global(a) {
		padding: 0.5rem 0.65rem;
		border-radius: var(--radius-sm);
		color: var(--brand-ink);
		font-weight: 600;
		font-size: 0.875rem;
		text-decoration: none;
	}
	.dropdown-panel :global(a:hover) {
		background: var(--accent-soft);
		color: var(--accent);
	}
	.dropdown-link {
		padding: 0.5rem 0.65rem;
		border-radius: var(--radius-sm);
		color: var(--brand-ink);
		font-weight: 600;
		font-size: 0.875rem;
		text-decoration: none;
	}
	.dropdown-link:hover {
		background: var(--accent-soft);
		color: var(--accent);
	}
	.dropdown-hr {
		margin: 0.4rem 0.35rem;
		border: none;
		border-top: 1px solid var(--border);
	}
	.dropdown-label {
		margin: 0.45rem 0.65rem 0.2rem;
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		font-weight: 700;
	}

	@media (max-width: 720px) {
		.header-search {
			max-width: 100%;
			width: 100%;
		}
		.dropdown-panel {
			position: static;
			border-radius: var(--radius);
			margin: 0.25rem 0 0.35rem;
			box-shadow: none;
			border: 1px solid var(--border);
			max-width: 100%;
		}
	}
</style>
