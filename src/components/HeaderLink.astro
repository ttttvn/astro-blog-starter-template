---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a"> & {
	/** Kích hoạt khi pathname bằng prefix hoặc là con của prefix. */
	matchPrefix?: string;
	/** Phân đoạn đầu tiên sau prefix bị loại (vd chu-de để tách danh sách bài vs chuyên mục). */
	prefixExclude?: string;
};

const { href, class: className, matchPrefix, prefixExclude, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const normalizedPath =
	pathname.length > 1 && pathname.endsWith("/")
		? pathname.slice(0, -1)
		: pathname;
const hrefStr = typeof href === "string" ? href : "";
const normalizedHref =
	hrefStr.length > 1 && hrefStr.endsWith("/") ? hrefStr.slice(0, -1) : hrefStr;
const subpath = normalizedPath.match(/[^/]+/g);
const rootMatch =
	normalizedHref === normalizedPath ||
	normalizedHref === "/" + (subpath?.[0] || "");

let prefixActive =
	Boolean(matchPrefix) &&
	(normalizedPath === matchPrefix ||
		Boolean(matchPrefix && normalizedPath.startsWith(matchPrefix + "/")));

if (prefixActive && matchPrefix && prefixExclude) {
	const after = normalizedPath.startsWith(matchPrefix + "/")
		? normalizedPath.slice(matchPrefix.length + 1)
		: "";
	const firstSeg = after.split("/")[0] ?? "";
	if (firstSeg === prefixExclude) {
		prefixActive = false;
	}
}

const isActive = rootMatch || prefixActive;
---

<a
	href={href}
	class:list={[className, { active: isActive }]}
	aria-current={isActive ? "page" : undefined}
	{...props}
>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: 700;
	}
</style>
