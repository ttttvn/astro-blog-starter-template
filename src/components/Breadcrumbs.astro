---
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	items: Crumb[];
}

const { items } = Astro.props;
const breadcrumbItems = items.filter((item) => item.label?.trim().length > 0);
const breadcrumbJson = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: breadcrumbItems.map((item, index) => ({
		"@type": "ListItem",
		position: index + 1,
		name: item.label,
		item: item.href ? new URL(item.href, Astro.site ?? Astro.url).toString() : Astro.url.toString(),
	})),
};
---

{
	breadcrumbItems.length > 0 && (
		<nav class="breadcrumbs" aria-label="Breadcrumb">
			<ol>
				{breadcrumbItems.map((item, idx) => (
					<li>
						{item.href && idx < breadcrumbItems.length - 1 ? (
							<a href={item.href}>{item.label}</a>
						) : (
							<span aria-current="page">{item.label}</span>
						)}
					</li>
				))}
			</ol>
		</nav>
	)
}

{
	breadcrumbItems.length > 0 && (
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />
	)
}

<style>
	.breadcrumbs {
		margin-bottom: 0.8rem;
	}
	.breadcrumbs ol {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem 0.55rem;
		font-size: 0.84rem;
		color: rgb(var(--gray));
	}
	.breadcrumbs li {
		display: inline-flex;
		align-items: center;
	}
	.breadcrumbs li + li::before {
		content: "/";
		margin-right: 0.55rem;
		color: #94a3b8;
	}
	.breadcrumbs a {
		color: var(--brand);
		text-decoration: none;
	}
	.breadcrumbs a:hover {
		text-decoration: underline;
	}
	.breadcrumbs [aria-current="page"] {
		color: rgb(var(--gray-dark));
		font-weight: 600;
	}
</style>
