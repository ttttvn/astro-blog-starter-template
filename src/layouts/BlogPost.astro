---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import {
	CATEGORY_LABELS,
	hsSlug,
	slugifyTag,
	type BlogCategory,
} from "../utils/blog";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	tags,
	hsCodes,
	effectiveDate,
	legalBasis,
} = Astro.props;

const categoryLabel = CATEGORY_LABELS[category as BlogCategory];
const ogImage = heroImage ?? "/favicon.svg";
---

<html lang="vi">
	<head>
		<BaseHead title={title} description={description} image={ogImage} />
		<style>
			main#main.post-shell {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--shadow-md);
			}
			.post-inner {
				width: min(1120px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1rem 1rem 2.5rem;
				display: grid;
				gap: 1.5rem;
				align-items: start;
			}
			@media (min-width: 960px) {
				.post-inner {
					grid-template-columns: minmax(0, 1fr) minmax(15rem, 17.5rem);
				}
			}
			.post-main {
				min-width: 0;
			}
			.post-sidebar {
				min-width: 0;
			}
			@media (min-width: 960px) {
				.post-sidebar {
					position: sticky;
					top: 4.75rem;
					align-self: start;
					max-height: calc(100vh - 5.5rem);
					overflow-y: auto;
				}
			}
			.meta-panel {
				background: var(--surface-elevated);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1rem 1.25rem;
				margin-bottom: 1rem;
				text-align: left;
				font-size: 0.92rem;
			}
			.post-toc {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 0.85rem 1rem;
				font-size: 0.88rem;
			}
			.post-toc.is-hidden {
				display: none;
			}
			.post-toc h2 {
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 0.07em;
				color: rgb(var(--gray));
				margin: 0 0 0.55rem;
			}
			.post-toc ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-toc li {
				margin-bottom: 0.35rem;
				line-height: 1.35;
			}
			.post-toc li.toc-h3 {
				padding-left: 0.85rem;
				font-size: 0.84rem;
			}
			.post-toc a {
				color: var(--brand-ink);
				text-decoration: none;
				font-weight: 600;
			}
			.post-toc a:hover {
				color: var(--accent);
				text-decoration: underline;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0 0.5em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta-panel h2 {
				font-size: 1.05rem;
				margin: 0 0 0.75rem 0;
			}
			.meta-row {
				margin: 0.35rem 0;
			}
			.badge {
				display: inline-block;
				background: var(--brand);
				color: #fff;
				padding: 0.2em 0.55em;
				border-radius: var(--radius-sm);
				font-size: 0.85rem;
				text-decoration: none;
				margin-right: 0.35rem;
			}
			.badge.secondary {
				background: #334155;
				color: #f8fafc;
			}
			.badge.secondary:hover {
				background: #1e40af;
				color: #fff;
			}
			.legal-list {
				margin: 0.25rem 0 0 1.1rem;
				padding: 0;
			}
			.article-body {
				color: rgb(var(--gray-dark));
				max-width: var(--prose-max);
				margin: 0 auto;
			}
			.article-body :global(h2),
			.article-body :global(h3) {
				scroll-margin-top: 5rem;
			}
			.disclaimer {
				margin-top: 2rem;
				padding-top: 1rem;
				border-top: 1px solid var(--border);
				font-size: 0.9rem;
				color: rgb(var(--gray));
				max-width: var(--prose-max);
				margin-left: auto;
				margin-right: auto;
			}
		</style>
	</head>

	<body>
		<Header />
		<main id="main" class="post-shell">
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="post-inner">
					<div class="post-main">
						<Breadcrumbs
							items={[
								{ label: "Trang chủ", href: "/" },
								{ label: "Chính sách & thủ tục", href: "/chinh-sach-thu-tuc/" },
								{ label: categoryLabel, href: `/blog/chu-de/${category}/` },
								{ label: title },
							]}
						/>
						<div class="title">
							<p class="date">
								<a class="badge" href={`/blog/chu-de/${category}/`} data-track="post-category">
									{categoryLabel}
								</a>
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<span class="last-updated-on">
											{" "}
											· Cập nhật <FormattedDate date={updatedDate} />
										</span>
									)
								}
							</p>
							<h1>{title}</h1>
							<hr />
						</div>

						<div id="article-body" class="article-body prose">
							<slot />
						</div>

						<p class="disclaimer">
							Nội dung mang tính hỗ trợ tra cứu và diễn giải; quyết định pháp lý cuối cùng thuộc văn
							bản do cơ quan nhà nước có thẩm quyền ban hành. Vui lòng đối chiếu bản chính và tham
							vấn chuyên gia khi áp dụng vào hồ sơ cụ thể.
						</p>
					</div>

					<aside class="post-sidebar" aria-label="Thông tin tra cứu và mục lục">
						<div class="meta-panel">
							<h2>Thông tin tra cứu</h2>
							{
								effectiveDate && (
									<p class="meta-row">
										<strong>Hiệu lực / thời điểm tham chiếu:</strong>{" "}
										<FormattedDate date={effectiveDate} />
									</p>
								)
							}
							{
								hsCodes.length > 0 && (
									<p class="meta-row">
										<strong>Mã HS gợi ý:</strong>{" "}
										{hsCodes.map((code) => (
											<a class="badge secondary" href={`/blog/hs/${hsSlug(code)}/`} data-track="post-hscode">
												{code}
											</a>
										))}
									</p>
								)
							}
							{
								tags.length > 0 && (
									<p class="meta-row">
										<strong>Nhãn:</strong>{" "}
										{tags.map((tag) => (
											<a
												class="badge secondary"
												href={`/blog/nhan/${slugifyTag(tag)}/`}
												data-track="post-tag"
											>
												{tag}
											</a>
										))}
									</p>
								)
							}
							{
								legalBasis.length > 0 && (
									<div class="meta-row">
										<strong>Căn cứ pháp lý</strong>
										<ul class="legal-list">
											{legalBasis.map((ref) => (
												<li>
													<a href={ref.href} target="_blank" rel="noopener noreferrer">
														{ref.label}
													</a>
												</li>
											))}
										</ul>
									</div>
								)
							}
						</div>
						<nav class="post-toc" id="post-toc" aria-label="Mục lục trong bài">
							<h2>Mục lục</h2>
							<ul id="article-toc-list"></ul>
						</nav>
					</aside>
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			(function () {
				function buildToc() {
					var body = document.getElementById("article-body");
					var tocNav = document.getElementById("post-toc");
					var list = document.getElementById("article-toc-list");
					if (!body || !tocNav || !list) return;
					var headings = body.querySelectorAll("h2, h3");
					if (headings.length < 2) {
						tocNav.classList.add("is-hidden");
						return;
					}
					var autoId = 0;
					headings.forEach(function (h) {
						if (!h.id) {
							autoId += 1;
							h.id = "muc-bai-" + autoId;
						}
						var li = document.createElement("li");
						li.className = h.tagName === "H3" ? "toc-h3" : "toc-h2";
						var a = document.createElement("a");
						a.href = "#" + h.id;
						a.textContent = h.textContent || "";
						li.appendChild(a);
						list.appendChild(li);
					});
				}
				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", buildToc);
				} else {
					buildToc();
				}
			})();
		</script>
	</body>
</html>
