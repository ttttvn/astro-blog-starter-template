---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { SITE_TITLE } from "../consts";

interface Props {
	frontmatter: {
		title: string;
		description: string;
	};
}

const { frontmatter } = Astro.props;
const pageTitle = `${frontmatter.title} | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={pageTitle} description={frontmatter.description} />
		<style>
			.docs-article {
				max-width: var(--prose-max);
			}
			.docs-article :global(h1) {
				margin-top: 0;
				font-size: clamp(1.5rem, 3vw, 1.85rem);
			}
			.docs-article :global(h2) {
				margin-top: 1.75rem;
				padding-top: 0.25rem;
				border-top: 1px solid var(--border);
			}
			.docs-article :global(h2:first-of-type) {
				border-top: none;
				padding-top: 0;
			}
			.docs-article :global(table) {
				font-size: 0.92rem;
			}
			.docs-article :global(hr) {
				margin: 1.75rem 0;
			}
			.docs-article :global(pre) {
				font-size: 0.82rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<Breadcrumbs items={[{ label: "Trang chủ", href: "/" }, { label: frontmatter.title }]} />
			<article class="docs-article prose">
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
