---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import {
	getPublishedPosts,
	CATEGORY_LABELS,
	type BlogCategory,
} from "../utils/blog";
import { normalizeSearchText } from "../utils/search";
import FormattedDate from "../components/FormattedDate.astro";

const title = `Tìm toàn văn — ${SITE_TITLE}`;
const posts = (await getPublishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const qRaw = Astro.url.searchParams.get("q") ?? "";
const q = qRaw.trim();
const qn = normalizeSearchText(q);

function postHaystack(p: (typeof posts)[number]): string {
	return normalizeSearchText(
		[
			p.data.title,
			p.data.description,
			CATEGORY_LABELS[p.data.category as BlogCategory],
			...p.data.tags,
			...p.data.hsCodes,
		].join(" "),
	);
}

const hits =
	q.length === 0
		? []
		: posts.filter((p) => postHaystack(p).includes(qn));

const suggestions = q.length === 0 ? posts.slice(0, 6) : [];
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead
			title={title}
			description="Tìm kiếm theo tiêu đề, tóm tắt, chuyên mục, nhãn hoặc mã HS trong các tin bài đã xuất bản trên cổng."
		/>
		<style>
			.page-head {
				margin-bottom: 1.5rem;
			}
			.search-form {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-items: center;
				margin-bottom: 1.25rem;
			}
			.search-form input[type="search"] {
				flex: 1;
				min-width: 12rem;
				max-width: 28rem;
			}
			.hint {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-bottom: 1.5rem;
			}
			.count {
				font-weight: 700;
				color: var(--brand);
				margin-bottom: 0.75rem;
			}
			.results {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
			}
			.results li {
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1rem 1.1rem;
				background: var(--surface);
			}
			.results a {
				text-decoration: none;
				color: inherit;
			}
			.results a:hover h2 {
				color: var(--accent);
			}
			.results h2 {
				font-size: 1.15rem;
				margin: 0 0 0.35rem;
			}
			.results .meta {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0 0 0.35rem;
			}
			.results .excerpt {
				margin: 0;
				font-size: 0.95rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<div class="page-head">
				<h1>Tìm toàn văn</h1>
				<p class="hint">
					Nhập từ khóa tiếng Việt (có hoặc không dấu), số mã HS, tên chuyên mục hoặc nhãn. Hệ thống
					so khớp trên tiêu đề, phần tóm tắt và các trường phân loại của tin bài.
				</p>
				<form class="search-form" method="get" action="/tim-kiem/">
					<label class="sr-only" for="q-main">Từ khóa tìm kiếm</label>
					<input
						id="q-main"
						type="search"
						name="q"
						value={qRaw}
						placeholder="Ví dụ: thực phẩm, 0402, hải quan…"
					/>
					<button type="submit" class="btn">Thực hiện tìm</button>
				</form>
			</div>

			{
				q.length > 0 && (
					<p class="count">
						{hits.length === 0
							? "Không có tin bài phù hợp với điều kiện tìm."
							: `Tìm thấy ${hits.length} tin bài.`}
					</p>
				)
			}

			{
				q.length > 0 && hits.length > 0 && (
					<ul class="results">
						{hits.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h2>{post.data.title}</h2>
									<p class="meta">
										{CATEGORY_LABELS[post.data.category as BlogCategory]} ·{" "}
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="excerpt">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)
			}

			{
				q.length === 0 && (
					<section class="card" aria-labelledby="suggest-h">
						<h2 id="suggest-h">Tin xuất bản gần đây</h2>
						<p class="hint" style="margin-bottom: 1rem;">
							Để tra theo danh mục cố định, vui lòng sử dụng mục <strong>Hỗ trợ tra cứu</strong> trên
							thanh điều hướng hoặc trang <a href="/tra-cuu/">chỉ mục HS và nhãn</a>.
						</p>
						<ul class="results">
							{suggestions.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<h2>{post.data.title}</h2>
										<p class="meta">
											{CATEGORY_LABELS[post.data.category as BlogCategory]} ·{" "}
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="excerpt">{post.data.description}</p>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
