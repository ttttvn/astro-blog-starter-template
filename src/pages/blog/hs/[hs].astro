---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../../consts";
import { getPublishedPosts, hsSlug } from "../../../utils/blog";
import FormattedDate from "../../../components/FormattedDate.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const slugs = new Set<string>();
	for (const p of posts) {
		for (const code of p.data.hsCodes) {
			slugs.add(hsSlug(code));
		}
	}
	return [...slugs].map((hs) => ({ params: { hs } }));
}

const hsParam = Astro.params.hs!;
const posts = (await getPublishedPosts())
	.filter((p) => p.data.hsCodes.some((c) => hsSlug(c) === hsParam))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const displayCode =
	posts.flatMap((p) => p.data.hsCodes).find((c) => hsSlug(c) === hsParam) ?? hsParam;

const title = `Mã HS ${displayCode} — ${SITE_TITLE}`;
const description = `Danh sách tin bài tham chiếu mã HS ${displayCode}. ${SITE_DESCRIPTION}`;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main id="main">
			<Breadcrumbs
				items={[
					{ label: "Trang chủ", href: "/" },
					{ label: "Công cụ tra cứu", href: "/cong-cu-tra-cuu/" },
					{ label: "Chỉ mục tra cứu", href: "/tra-cuu/" },
					{ label: `HS ${displayCode}` },
				]}
			/>
			<h1>Tin theo mã HS: {displayCode}</h1>
			<p>
				<a href="/blog/">← Danh sách tin bài</a>
				{" · "}
				<a href="/tra-cuu/#ma-hs">Danh mục HS</a>
			</p>
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<strong>{post.data.title}</strong>
							</a>
							{" — "}
							<FormattedDate date={post.data.pubDate} />
						</li>
					))
				}
			</ul>
			{posts.length === 0 && <p>Chưa có tin bài nào tham chiếu mã HS này.</p>}
		</main>
		<Footer />
	</body>
</html>
