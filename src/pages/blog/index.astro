---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getPublishedPosts } from "../../utils/blog";
import { CATEGORY_LABELS, type BlogCategory } from "../../utils/blog";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getPublishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const title = `Bài viết — ${SITE_TITLE}`;
const categories = Object.keys(CATEGORY_LABELS) as BlogCategory[];
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={SITE_DESCRIPTION} />
		<style>
			.page-intro {
				margin-bottom: 1.25rem;
			}
			.toolbar {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.65rem;
				margin-bottom: 1.75rem;
				padding: 0.85rem 1rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius);
			}
			.toolbar-label {
				font-size: 0.78rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
				margin-right: 0.25rem;
			}
			.chips {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				flex: 1;
			}
			.chips a {
				text-decoration: none;
			}
			ul.posts {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul.posts li a {
				display: block;
				height: 100%;
				text-decoration: none;
				color: inherit;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1rem 1.05rem;
				background: var(--surface);
				transition:
					border-color 0.15s,
					box-shadow 0.15s;
			}
			ul.posts li a:hover {
				border-color: var(--accent);
				box-shadow: var(--shadow-md);
			}
			.thumb {
				display: block;
				width: 100%;
				aspect-ratio: 16 / 9;
				border-radius: var(--radius-sm);
				margin-bottom: 0.65rem;
				background: linear-gradient(
					135deg,
					rgba(var(--gray-light), 1) 0%,
					rgba(13, 148, 136, 0.15) 100%
				);
				overflow: hidden;
			}
			.thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.cat {
				display: inline-block;
				font-size: 0.78rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: var(--brand-muted);
				margin-bottom: 0.35rem;
			}
			.title {
				margin: 0 0 0.35rem;
				font-size: 1.1rem;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.date {
				margin: 0;
				font-size: 0.88rem;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="page-intro">
				<h1>Bài viết</h1>
				<p>
					Lọc nhanh theo chủ đề hoặc mở <a href="/tim-kiem/">Tìm kiếm</a> / <a href="/tra-cuu/"
						>Trung tâm tra cứu</a
					> để theo HS và nhãn.
				</p>
			</section>

			<div class="toolbar" role="navigation" aria-label="Lọc theo chủ đề">
				<span class="toolbar-label">Chủ đề</span>
				<div class="chips">
					<a class="pill" href="/blog/chu-de/">Tất cả nhóm</a>
					{
						categories.map((key) => (
							<a class="pill" href={`/blog/chu-de/${key}/`}>
								{CATEGORY_LABELS[key]}
							</a>
						))
					}
				</div>
			</div>

			<section>
				<ul class="posts">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="thumb">
										{post.data.heroImage && (
											<img width={640} height={360} src={post.data.heroImage} alt="" />
										)}
									</span>
									<span class="cat">{CATEGORY_LABELS[post.data.category as BlogCategory]}</span>
									<h2 class="title">{post.data.title}</h2>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
