---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getPublishedPosts } from "../../utils/blog";
import { CATEGORY_LABELS, type BlogCategory } from "../../utils/blog";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getPublishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const title = `Bài viết — ${SITE_TITLE}`;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.page-intro {
				margin-bottom: 2rem;
			}
			.page-intro a {
				font-weight: 600;
			}
			ul.posts {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul.posts li {
				width: calc(50% - 1rem);
			}
			ul.posts li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul.posts li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul.posts li:first-child .title {
				font-size: 2.369rem;
			}
			.thumb {
				display: block;
				width: 100%;
				aspect-ratio: 2 / 1;
				border-radius: 12px;
				margin-bottom: 0.5rem;
				background: linear-gradient(
					135deg,
					rgba(var(--gray-light), 1) 0%,
					rgba(var(--gray), 0.25) 100%
				);
				box-shadow: var(--box-shadow);
				overflow: hidden;
			}
			.thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 12px;
			}
			.title {
				margin: 0.25rem 0 0 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.cat {
				display: inline-block;
				margin-top: 0.35rem;
				font-size: 0.85rem;
				color: var(--accent-dark);
				font-weight: 600;
			}
			ul.posts li a:hover h4,
			ul.posts li a:hover .date {
				color: rgb(var(--accent));
			}
			ul.posts a:hover .thumb {
				box-shadow:
					0 2px 8px rgba(var(--gray), 35%),
					0 12px 28px rgba(var(--gray), 28%);
			}
			@media (max-width: 720px) {
				ul.posts {
					gap: 0.5em;
				}
				ul.posts li {
					width: 100%;
					text-align: center;
				}
				ul.posts li:first-child {
					margin-bottom: 0;
				}
				ul.posts li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-intro">
				<h1>Bài viết</h1>
				<p>
					Lọc theo <a href="/blog/chu-de/">chủ đề</a> hoặc xem toàn bộ danh sách bên dưới.
				</p>
			</section>
			<section>
				<ul class="posts">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="thumb">
										{post.data.heroImage && (
											<img width={720} height={360} src={post.data.heroImage} alt="" />
										)}
									</span>
									<span class="cat">
										{CATEGORY_LABELS[post.data.category as BlogCategory]}
									</span>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
