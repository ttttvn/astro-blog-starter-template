---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../../consts";
import {
	CATEGORY_LABELS,
	getPublishedPosts,
	isBlogCategory,
	type BlogCategory,
} from "../../../utils/blog";

const posts = await getPublishedPosts();
const counts = {} as Record<BlogCategory, number>;
for (const c of Object.keys(CATEGORY_LABELS) as BlogCategory[]) {
	counts[c] = 0;
}
for (const p of posts) {
	if (isBlogCategory(p.data.category)) {
		counts[p.data.category]++;
	}
}
const title = `Chủ đề — ${SITE_TITLE}`;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Chủ đề</h1>
			<p>Chọn nhóm nội dung để xem các bài viết liên quan.</p>
			<ul>
				{
					(Object.keys(CATEGORY_LABELS) as BlogCategory[]).map((key) => (
						<li>
							<a href={`/blog/chu-de/${key}/`}>
								<strong>{CATEGORY_LABELS[key]}</strong>
								<span> — {counts[key]} bài</span>
							</a>
						</li>
					))
				}
			</ul>
			<p>
				<a href="/blog/">← Tất cả bài viết</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
