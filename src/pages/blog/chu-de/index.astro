---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../../consts";
import {
	CATEGORY_LABELS,
	CATEGORY_HINTS,
	getPublishedPosts,
	isBlogCategory,
	type BlogCategory,
} from "../../../utils/blog";

const posts = await getPublishedPosts();
const counts = {} as Record<BlogCategory, number>;
for (const c of Object.keys(CATEGORY_LABELS) as BlogCategory[]) {
	counts[c] = 0;
}
for (const p of posts) {
	if (isBlogCategory(p.data.category)) {
		counts[p.data.category]++;
	}
}
const title = `Chủ đề — ${SITE_TITLE}`;
const categories = Object.keys(CATEGORY_LABELS) as BlogCategory[];
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={SITE_DESCRIPTION} />
		<style>
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 1rem;
				margin: 1.5rem 0;
			}
			.grid a {
				text-decoration: none;
				color: inherit;
				height: 100%;
			}
			.card {
				height: 100%;
				transition:
					border-color 0.15s,
					box-shadow 0.15s;
			}
			.grid a:hover .card {
				border-color: var(--accent);
				box-shadow: var(--shadow-md);
			}
			.count {
				display: block;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				font-weight: 600;
				margin-top: 0.35rem;
			}
			.card h2 {
				margin: 0 0 0.4rem;
				font-size: 1.1rem;
				color: var(--brand);
			}
			.card p {
				margin: 0;
				font-size: 0.92rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<h1>Phân loại theo chuyên mục</h1>
			<p>
				Chọn một trong bốn chuyên mục để xem danh sách tin bài thuộc chuyên mục đó. Mỗi thẻ hiển thị
				số lượng bài hiện có.
			</p>
			<div class="grid">
				{
					categories.map((key) => (
						<a href={`/blog/chu-de/${key}/`}>
							<div class="card">
								<h2>{CATEGORY_LABELS[key]}</h2>
								<p>{CATEGORY_HINTS[key]}</p>
								<span class="count">{counts[key]} bài</span>
							</div>
						</a>
					))
				}
			</div>
			<p>
				<a href="/blog/">← Danh sách tin bài</a>
				{" · "}
				<a href="/tra-cuu/">Chỉ mục HS và nhãn</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
