---
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../../consts";
import { getPublishedPosts, slugifyTag } from "../../../utils/blog";
import FormattedDate from "../../../components/FormattedDate.astro";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const slugs = new Set<string>();
	for (const p of posts) {
		for (const t of p.data.tags) {
			slugs.add(slugifyTag(t));
		}
	}
	return [...slugs].map((tag) => ({ params: { tag } }));
}

const tagSlug = Astro.params.tag!;
const posts = (await getPublishedPosts())
	.filter((p) => p.data.tags.some((t) => slugifyTag(t) === tagSlug))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const displayTag =
	posts.flatMap((p) => p.data.tags).find((t) => slugifyTag(t) === tagSlug) ?? tagSlug;

const title = `Nhãn «${displayTag}» — ${SITE_TITLE}`;
const description = `Danh sách tin bài gắn nhãn «${displayTag}». ${SITE_DESCRIPTION}`;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main id="main">
			<h1>Tin theo nhãn: {displayTag}</h1>
			<p>
				<a href="/blog/">← Danh sách tin bài</a>
				{" · "}
				<a href="/tra-cuu/#nhan">Chỉ mục nhãn</a>
			</p>
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<strong>{post.data.title}</strong>
							</a>
							{" — "}
							<FormattedDate date={post.data.pubDate} />
						</li>
					))
				}
			</ul>
			{posts.length === 0 && <p>Không có tin bài nào gắn nhãn này.</p>}
		</main>
		<Footer />
	</body>
</html>
