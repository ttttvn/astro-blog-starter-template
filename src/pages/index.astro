---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import {
	getPublishedPosts,
	CATEGORY_LABELS,
	CATEGORY_HINTS,
	CATEGORY_IMPACT_LABELS,
	type BlogCategory,
} from "../utils/blog";
import FormattedDate from "../components/FormattedDate.astro";

const allPosts = (await getPublishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, 5);

const categories = Object.keys(CATEGORY_LABELS) as BlogCategory[];
const quickStats = [
	{ label: "Bài đã xuất bản", value: `${allPosts.length}` },
	{ label: "Nhóm chuyên mục", value: `${categories.length}` },
];

const workflowSteps = [
	{
		title: "Trước hợp đồng",
		blurb: "Rà HS, cấm/hạn chế và điều kiện nhập — tránh rủi ro ký nhầm mặt hàng.",
		href: "/blog/chu-de/cam-han-che/",
		track: "home-workflow-pre-contract",
	},
	{
		title: "Chuẩn bị hồ sơ & tờ khai",
		blurb: "Checklist chứng từ, điều kiện chuyên ngành và mô tả hàng thống nhất.",
		href: "/blog/chu-de/xnk-co-dieu-kien/",
		track: "home-workflow-docs",
	},
	{
		title: "Sau thông quan",
		blurb: "Đối soát nội bộ, lưu trữ và theo dõi thay đổi pháp lý định kỳ.",
		href: "/co-che-to-chuc-xnk/",
		track: "home-workflow-post",
	},
] as const;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				background: linear-gradient(135deg, #1e3a8a 0%, #1d4ed8 48%, #2563eb 100%);
				color: #eff6ff;
				border-radius: var(--radius);
				padding: 2rem 1.75rem;
				margin-bottom: 2rem;
				box-shadow: var(--shadow-md);
				border: 1px solid rgba(255, 255, 255, 0.12);
			}
			.hero-eyebrow {
				display: inline-block;
				margin-bottom: 0.55rem;
				font-size: 0.8rem;
				letter-spacing: 0.07em;
				text-transform: uppercase;
				font-weight: 700;
				opacity: 0.9;
			}
			.hero h1 {
				color: #fff;
				margin: 0 0 0.75rem;
				font-size: clamp(1.55rem, 3.5vw, 2rem);
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.hero p {
				margin: 0 0 1.25rem;
				opacity: 0.96;
				max-width: 48ch;
			}
			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
				margin-bottom: 1.1rem;
			}
			.hero .btn {
				background: #fff;
				color: var(--brand);
			}
			.hero .btn:hover {
				background: #ecfeff;
				color: var(--brand-muted);
			}
			.hero .btn-ghost {
				border-color: rgba(255, 255, 255, 0.45);
				color: #fff;
			}
			.hero .btn-ghost:hover {
				background: rgba(255, 255, 255, 0.12);
				color: #fff;
			}
			.quick-stats {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}
			.stat-card {
				background: rgba(15, 23, 42, 0.2);
				border: 1px solid rgba(255, 255, 255, 0.24);
				border-radius: var(--radius-sm);
				padding: 0.55rem 0.8rem;
				min-width: 10rem;
			}
			.stat-value {
				display: block;
				font-weight: 700;
				font-size: 1.1rem;
				color: #fff;
				line-height: 1.2;
			}
			.stat-label {
				font-size: 0.78rem;
				color: #dbeafe;
			}
			.section-title {
				margin-bottom: 0.75rem;
			}
			.section-lead {
				color: rgb(var(--gray));
				margin: 0 0 1.25rem;
			}
			.menu-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.9rem;
				margin: 0 0 2rem;
			}
			.menu-grid a {
				text-decoration: none;
				color: inherit;
			}
			.menu-grid .card {
				height: 100%;
				transition:
					border-color 0.15s,
					box-shadow 0.15s;
			}
			.menu-grid .card:hover {
				border-color: rgba(37, 99, 235, 0.45);
				box-shadow: var(--shadow-md);
			}
			.menu-grid h3 {
				margin: 0 0 0.4rem;
				font-size: 1.02rem;
				color: var(--brand);
			}
			.menu-grid p {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
			}
			.cat-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1rem;
				margin-bottom: 2.5rem;
			}
			.cat-grid a {
				text-decoration: none;
				color: inherit;
				height: 100%;
			}
			.cat-grid .card {
				height: 100%;
				transition:
					border-color 0.15s,
					box-shadow 0.15s;
			}
			.cat-grid .card:hover {
				border-color: rgba(37, 99, 235, 0.45);
				box-shadow: var(--shadow-md);
			}
			.cat-grid h3 {
				margin: 0 0 0.4rem;
				font-size: 1.05rem;
				color: var(--brand);
			}
			.cat-grid p {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
			}
			.recent ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
			}
			.recent li {
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1rem 1.1rem;
				background: var(--surface);
			}
			.recent a {
				text-decoration: none;
				color: inherit;
			}
			.recent a:hover h3 {
				color: var(--accent-hover);
			}
			.recent h3 {
				margin: 0 0 0.35rem;
				font-size: 1.1rem;
			}
			.meta {
				font-size: 0.88rem;
				color: rgb(var(--gray));
				margin: 0 0 0.35rem;
			}
			.excerpt {
				margin: 0;
				font-size: 0.95rem;
			}
			.more {
				margin-top: 1rem;
			}
			.newsletter {
				margin-top: 2.4rem;
				padding: 1.15rem 1.2rem;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				background: var(--surface);
			}
			.newsletter h2 {
				margin-bottom: 0.45rem;
			}
			.newsletter p {
				margin: 0 0 0.65rem;
				color: rgb(var(--gray-dark));
			}
			.newsletter-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}
			.workflow {
				margin-bottom: 2.25rem;
			}
			.workflow-steps {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 1rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.workflow-steps a {
				display: block;
				height: 100%;
				text-decoration: none;
				color: inherit;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1.1rem 1.15rem;
				background: var(--surface);
				box-shadow: var(--shadow-sm);
				transition:
					border-color 0.15s,
					box-shadow 0.15s;
			}
			.workflow-steps a:hover {
				border-color: rgba(37, 99, 235, 0.45);
				box-shadow: var(--shadow-md);
			}
			.workflow-steps .step-num {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 1.65rem;
				height: 1.65rem;
				border-radius: 999px;
				background: var(--accent-soft-strong);
				color: var(--brand-deep);
				font-weight: 800;
				font-size: 0.82rem;
				margin-bottom: 0.5rem;
			}
			.workflow-steps h3 {
				margin: 0 0 0.35rem;
				font-size: 1.05rem;
				color: var(--brand-ink);
			}
			.workflow-steps p {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
			}
			.workflow-steps .step-cta {
				display: inline-block;
				margin-top: 0.65rem;
				font-size: 0.84rem;
				font-weight: 700;
				color: var(--accent);
			}
			.impact {
				display: inline-block;
				margin-right: 0.45rem;
				padding: 0.15rem 0.5rem;
				border-radius: 999px;
				background: var(--accent-soft-strong);
				color: var(--brand-ink);
				font-size: 0.72rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				vertical-align: middle;
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<section class="hero">
				<span class="hero-eyebrow">FASTPORT — Cổng tra cứu XNK</span>
				<h1>Cổng thông tin chính sách mặt hàng & thủ tục XNK</h1>
				<p>{SITE_DESCRIPTION}</p>
				<div class="hero-actions">
					<a class="btn" href="/danh-cho-dn-xnk/" data-track="home-hero-start">Bắt đầu cho DN XNK</a>
					<a class="btn btn-ghost" href="/chinh-sach-thu-tuc/" data-track="home-hero-policy">Danh mục mặt hàng</a>
					<a class="btn btn-ghost" href="/tim-kiem/" data-track="home-hero-search">Tìm toàn văn</a>
					<a class="btn btn-ghost" href="/about" data-track="home-hero-contact">Liên hệ</a>
				</div>
				<div class="quick-stats">
					{
						quickStats.map((stat) => (
							<div class="stat-card">
								<span class="stat-value">{stat.value}</span>
								<span class="stat-label">{stat.label}</span>
							</div>
						))
					}
				</div>
			</section>

			<section class="workflow" aria-labelledby="workflow-h">
				<h2 id="workflow-h" class="section-title">Luồng làm việc phổ biến</h2>
				<p class="section-lead">
					Ba bước mô phỏng thực tế phòng XNK: từ rà soát trước ký kết đến sau thông quan. Mỗi thẻ mở đúng
					nhóm nội dung liên quan.
				</p>
				<ol class="workflow-steps">
					{
						workflowSteps.map((step, i) => (
							<li>
								<a href={step.href} data-track={step.track}>
									<span class="step-num">{i + 1}</span>
									<h3>{step.title}</h3>
									<p>{step.blurb}</p>
									<span class="step-cta">Vào bước này →</span>
								</a>
							</li>
						))
					}
				</ol>
			</section>

			<section aria-labelledby="menu-h">
				<h2 id="menu-h" class="section-title">Điều hướng nhanh</h2>
				<p class="section-lead">
					Bốn cụm chính theo mô hình FASTPORT: chính sách, hỗ trợ doanh nghiệp, cơ chế nội bộ và tra cứu.
				</p>
				<div class="menu-grid">
					<a href="/chinh-sach-thu-tuc/" data-track="home-quick-policy">
						<div class="card">
							<h3>Chính sách & thủ tục</h3>
							<p>Tổng mục mặt hàng, nhóm chế độ quản lý và luồng thủ tục nền tảng.</p>
						</div>
					</a>
					<a href="/danh-cho-dn-xnk/" data-track="home-quick-enterprise">
						<div class="card">
							<h3>Dành cho DN XNK</h3>
							<p>Bộ nội dung áp dụng thực tế cho đội chứng từ và vận hành xuất nhập khẩu.</p>
						</div>
					</a>
					<a href="/co-che-to-chuc-xnk/" data-track="home-quick-operating-model">
						<div class="card">
							<h3>Cơ chế & tổ chức XNK</h3>
							<p>Vai trò, phân công và checklist phối hợp nội bộ trước khi khai báo.</p>
						</div>
					</a>
					<a href="/cong-cu-tra-cuu/" data-track="home-quick-tools">
						<div class="card">
							<h3>Công cụ tra cứu</h3>
							<p>Tìm toàn văn, theo nhãn/HS và các điểm vào nhanh cho tra cứu nghiệp vụ.</p>
						</div>
					</a>
				</div>
			</section>

			<section aria-labelledby="cat-h">
				<h2 id="cat-h" class="section-title">Phân loại theo chuyên mục nội dung</h2>
				<p class="section-lead">Giữ nguyên taxonomy hiện có để không phá dữ liệu đã đăng từ CMS.</p>
				<div class="cat-grid">
					{
						categories.map((key) => (
							<a href={`/blog/chu-de/${key}/`} data-track="home-category-card">
								<div class="card">
									<h3>{CATEGORY_LABELS[key]}</h3>
									<p>{CATEGORY_HINTS[key]}</p>
								</div>
							</a>
						))
					}
				</div>
			</section>

			<section class="recent" aria-labelledby="recent-h">
				<h2 id="recent-h" class="section-title">Tin mới đăng</h2>
				<p class="section-lead">
					Các bài xuất bản gần nhất. Để lọc theo từ khóa, mã HS hoặc nhãn, sử dụng mục <strong
						>Hỗ trợ tra cứu</strong
					> trên thanh điều hướng hoặc ô tìm kiếm phía trên.
				</p>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} data-track="home-latest-post">
									<h3>{post.data.title}</h3>
									<p class="meta">
										<span class="impact">
											{CATEGORY_IMPACT_LABELS[post.data.category as BlogCategory]}
										</span>
										{CATEGORY_LABELS[post.data.category as BlogCategory]} ·{" "}
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="excerpt">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
				<p class="more">
					<a class="btn btn-ghost" href="/blog/" data-track="home-view-all-posts">Xem toàn bộ tin bài</a>
				</p>
			</section>
			<section class="newsletter" aria-labelledby="news-h">
				<h2 id="news-h">Bản tin & cập nhật</h2>
				<p>
					Gợi ý cho đội chứng từ và XNK: theo dõi khi có thay đổi biểu thuế, danh mục cấm/hạn chế và
					quy định kiểm tra chuyên ngành.
				</p>
				<div class="newsletter-actions">
					<a class="btn" href="/rss.xml" data-track="home-news-rss">Đăng ký RSS</a>
					<a class="btn btn-ghost" href="/cong-cu-tra-cuu/" data-track="home-news-tools">
						Mở công cụ tra cứu
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
